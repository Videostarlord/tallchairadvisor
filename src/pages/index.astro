---
import Layout from '../layouts/Layout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Tall Chair Advisor",
    "url": "https://tallchairadvisor.com/",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://tallchairadvisor.com/?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://tallchairadvisor.com/#organization",
    "name": "Tall Chair Advisor",
    "url": "https://tallchairadvisor.com/",
    "logo": { "@type": "ImageObject", "url": "https://tallchairadvisor.com/images/og-default.jpg" },
    "description": "Independent ergonomic chair guidance for tall people.",
    "founder": { "@id": "https://tallchairadvisor.com/about/#author" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What chairs work for people over 6 feet tall?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The best office chairs for people over 6 feet tall are the Herman Miller Aeron Size C, Steelcase Leap Plus, and Steelcase Gesture. These chairs offer seat heights, seat depths, and back heights that can accommodate taller frames. The Leap Plus has the highest seat ceiling at 22.5 inches, making it the best option for users 6'4 and above."
        }
      },
      {
        "@type": "Question",
        "name": "What seat height do I need if I'm 6'4\"?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "At 6'4\", you typically need a seat height of 20–22 inches to achieve a neutral seated position with thighs parallel to the floor. Most standard office chairs max out at 18–20 inches, which is insufficient. Look for chairs with a maximum seat height of at least 21 inches, or the Steelcase Leap Plus which reaches 22.5 inches."
        }
      },
      {
        "@type": "Question",
        "name": "What's the difference between the Aeron Size C and the Steelcase Gesture?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Herman Miller Aeron Size C uses a Pellicle mesh suspension for breathability and has a fixed seat depth of approximately 18.5 inches. The Steelcase Gesture uses foam upholstery, has an adjustable seat depth (15.75–18.75 inches), and features a 360-degree armrest system designed for multi-device work. The Aeron suits users who prioritize breathability; the Gesture suits those who need maximum arm flexibility or sit on a firm surface preference."
        }
      },
      {
        "@type": "Question",
        "name": "Why do standard office chairs cause back pain for tall people?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Standard office chairs are designed for users up to about 6'2\". For taller users, the lumbar support lands too low on the spine, the seat may not raise high enough, and the backrest may not reach the shoulder blades. These mismatches create compensatory postures — forward head, rounded shoulders, posterior pelvic tilt — that cause cumulative back, neck, and shoulder pain."
        }
      },
      {
        "@type": "Question",
        "name": "What seat depth do tall people need in an office chair?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tall people generally need a seat depth of 18–21 inches depending on their thigh length. The standard test: sit fully back against the lumbar support and measure from the backrest to 2–3 fingers in front of your knee crease. If your chair's maximum depth falls short of this measurement, the seat edge will press into your knees when you sit correctly."
        }
      }
    ]
  }
];
---

<Layout
  title="Expert Chair Reviews for Tall People | Tall Chair Advisor"
  description="Independent expert guidance on ergonomic office chairs for people 6 feet and taller. Reviews, fit guides, and pain solutions."
  schema={schema}
>
  <!-- Hero Section -->
  <section class="py-16 md:py-24 lg:py-32 bg-gradient-to-b from-secondary/50 to-background">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-balance">
          Expert Chair Guidance for Tall People
        </h1>
        <p class="mt-6 text-lg md:text-xl text-muted-foreground animate-slide-up">
          Finding the right office chair when you're tall shouldn't be guesswork.
          We provide independent, research-backed guidance to help you sit comfortably.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/office-chairs-for-tall-people/"
            class="inline-flex items-center px-6 py-3 bg-primary text-primary-foreground rounded-lg font-medium hover:bg-primary/90 transition-colors"
          >
            Start Here
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="/pain-ergonomics/"
            class="inline-flex items-center px-6 py-3 bg-secondary text-secondary-foreground rounded-lg font-medium hover:bg-secondary/80 transition-colors"
          >
            Explore Pain Solutions
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- About Jackson -->
  <section class="py-14 border-b border-border bg-card/50">
    <div class="container-article">
      <div class="flex flex-col sm:flex-row gap-8 items-start">
        <img
          src="/images/jackson-christopher.webp"
          alt="Jackson Christopher, founder of Tall Chair Advisor"
          width="128"
          height="128"
          class="rounded-lg object-cover flex-shrink-0 w-28 h-28 sm:w-32 sm:h-32"
          loading="lazy"
        />
        <div>
          <h2 class="font-serif text-2xl text-heading mb-3">Why This Site Exists</h2>
          <p class="text-muted-foreground mb-3">
            I'm Jackson Christopher — 6'4", a Mechanical Engineering senior at UC Berkeley.
            For years I dealt with lower back pain and shoulder tension that I blamed on long
            study sessions. The real problem was simpler: every chair I owned was designed for
            someone shorter than me. Seat height too low, lumbar support in the wrong place,
            backrest ending below my shoulder blades.
          </p>
          <p class="text-muted-foreground mb-4">
            I started systematically testing chairs in 2019 to solve my own problem. What I found
            was that every major buying guide was written for people 5'6"–5'11" — and the
            recommendations reflected it. I built Tall Chair Advisor to be the resource I
            couldn't find: dimension-first, engineering-grounded, and written by someone who
            literally can't fit in standard chairs.
          </p>
          <div class="text-sm text-muted-foreground mb-2">
            <strong class="text-heading">How I test:</strong> I verify manufacturer specs against physical measurements,
            evaluate chairs at the extremes of their adjustment range (where tall users actually
            sit), and use every primary review chair as my main seat for a minimum of 3–4 weeks
            before drawing conclusions. 15+ chairs tested over 6+ years.
          </div>
          <a href="/about/" class="inline-flex items-center text-sm text-primary font-medium hover:text-primary/80 mt-2">
            Full methodology →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Top Pick CTA -->
  <section class="py-10 bg-primary/5 border-b border-border">
    <div class="container-article text-center">
      <p class="text-muted-foreground mb-3 text-sm font-medium uppercase tracking-wide">Ready to find your chair?</p>
      <h2 class="font-serif text-2xl text-heading mb-4">See the Top Picks for Tall People</h2>
      <p class="text-muted-foreground mb-6 max-w-xl mx-auto">
        Three chairs that meet dimensional requirements for users 6'0" and taller — with exact specs and height-specific fit guidance.
      </p>
      <a
        href="/best-office-chairs/"
        class="inline-flex items-center px-6 py-3 bg-primary text-primary-foreground rounded-lg font-medium hover:bg-primary/90 transition-colors"
      >
        View Best Office Chairs
        <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Value Props -->
  <section class="py-16 border-b border-border">
    <div class="container-wide">
      <h2 class="sr-only">What Tall Chair Advisor Covers</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="mx-auto w-12 h-12 rounded-full bg-accent flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-serif text-lg font-medium text-heading mb-2">For Tall Users</h3>
          <p class="text-sm text-muted-foreground">
            Content specifically created for people 6'0" and taller who struggle with standard office chairs.
          </p>
        </div>
        <div class="text-center">
          <div class="mx-auto w-12 h-12 rounded-full bg-accent flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
            </svg>
          </div>
          <h3 class="font-serif text-lg font-medium text-heading mb-2">Dimension-Focused</h3>
          <p class="text-sm text-muted-foreground">
            We analyze seat depth, height ranges, and back support dimensions that matter for larger frames.
          </p>
        </div>
        <div class="text-center">
          <div class="mx-auto w-12 h-12 rounded-full bg-accent flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
          </div>
          <h3 class="font-serif text-lg font-medium text-heading mb-2">Independent Reviews</h3>
          <p class="text-sm text-muted-foreground">
            Honest evaluations based on ergonomic principles, not marketing claims.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Hub Navigation - Layer 1 -->
  <section class="py-16">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="font-serif text-heading">Understand the Problem</h2>
        <p class="mt-3 text-muted-foreground max-w-xl mx-auto">
          Learn why standard chairs fail tall people and how specific pain points connect to chair design.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/office-chairs-for-tall-people/" class="group card-hub flex flex-col">
          <h3 class="font-serif text-xl font-medium text-heading mb-2 group-hover:text-primary transition-colors">
            Office Chairs for Tall People
          </h3>
          <p class="text-sm text-muted-foreground flex-1 mb-4">
            The complete introduction to why finding the right chair matters for your health and productivity.
          </p>
          <div class="flex items-center text-sm font-medium text-primary">
            Learn more
            <svg class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
        <a href="/pain-ergonomics/" class="group card-hub flex flex-col">
          <h3 class="font-serif text-xl font-medium text-heading mb-2 group-hover:text-primary transition-colors">
            Pain & Ergonomics Hub
          </h3>
          <p class="text-sm text-muted-foreground flex-1 mb-4">
            Explore how chair dimensions directly cause knee pain, back pain, and circulation issues.
          </p>
          <div class="flex items-center text-sm font-medium text-primary">
            Learn more
            <svg class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
        <a href="/why-standard-chairs-dont-fit/" class="group card-hub flex flex-col">
          <h3 class="font-serif text-xl font-medium text-heading mb-2 group-hover:text-primary transition-colors">
            Why Standard Chairs Don't Fit
          </h3>
          <p class="text-sm text-muted-foreground flex-1 mb-4">
            Understand the fundamental design limitations that make most chairs unsuitable for tall users.
          </p>
          <div class="flex items-center text-sm font-medium text-primary">
            Learn more
            <svg class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Hub Navigation - Layer 2 -->
  <section class="py-16 bg-secondary/30">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="font-serif text-heading">Learn to Evaluate</h2>
        <p class="mt-3 text-muted-foreground max-w-xl mx-auto">
          Guides for measuring fit and adjusting chairs to work with your body dimensions.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <a href="/fit-guides/" class="group card-hub flex flex-col">
          <h3 class="font-serif text-xl font-medium text-heading mb-2 group-hover:text-primary transition-colors">
            Fit & Adjustment Guides
          </h3>
          <p class="text-sm text-muted-foreground flex-1 mb-4">
            Step-by-step instructions for evaluating chair fit and making proper adjustments.
          </p>
          <div class="flex items-center text-sm font-medium text-primary">
            Learn more
            <svg class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
        <a href="/correct-chair-dimensions/" class="group card-hub flex flex-col">
          <h3 class="font-serif text-xl font-medium text-heading mb-2 group-hover:text-primary transition-colors">
            Correct Chair Dimensions
          </h3>
          <p class="text-sm text-muted-foreground flex-1 mb-4">
            The specific measurements and ranges tall users should look for when evaluating chairs.
          </p>
          <div class="flex items-center text-sm font-medium text-primary">
            Learn more
            <svg class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- About Link -->
  <section class="py-16">
    <div class="container-article text-center">
      <h2 class="font-serif text-2xl text-heading mb-4">About Tall Chair Advisor</h2>
      <p class="text-muted-foreground mb-6">
        Learn about our approach to evaluating office chairs and why we focus exclusively on tall users.
      </p>
      <a href="/about/" class="inline-flex items-center text-primary font-medium hover:text-primary/80">
        About Us
        <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
