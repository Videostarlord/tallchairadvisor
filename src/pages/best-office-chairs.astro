---
import Layout from '../layouts/Layout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Best Office Chairs for Tall People 2026",
    "url": "https://tallchairadvisor.com/best-office-chairs/",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Herman Miller Aeron Size C", "url": "https://tallchairadvisor.com/review/aeron-size-c/" },
      { "@type": "ListItem", "position": 2, "name": "Steelcase Leap Plus", "url": "https://tallchairadvisor.com/review/leap-plus/" },
      { "@type": "ListItem", "position": 3, "name": "Steelcase Gesture", "url": "https://tallchairadvisor.com/review/gesture/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tallchairadvisor.com/" },
      { "@type": "ListItem", "position": 2, "name": "Best Office Chairs", "item": "https://tallchairadvisor.com/best-office-chairs/" }
    ]
  }
];

const chairs = [
  {
    name: "Herman Miller Aeron Size C",
    suitability: 'Users 6\'0" to 6\'6" with average to lean builds',
    strengths: ["Extensive adjustability", "Proven long-term durability", "Excellent ventilation"],
    considerations: ["Mesh may not suit all preferences", "Premium pricing"],
    reviewHref: "/review/aeron-size-c",
    compareLinks: [
      { name: "vs Steelcase Leap Plus", href: "/aeron-vs-leap-plus" },
      { name: "vs Steelcase Gesture", href: "/aeron-vs-gesture" },
    ],
  },
  {
    name: "Steelcase Leap Plus",
    suitability: 'Users 6\'0" to 6\'6" with larger builds, up to 500 lbs',
    strengths: ["Higher weight capacity", "Deep seat option", "Flexible back support"],
    considerations: ["Heavier unit", "Less ventilation than mesh"],
    reviewHref: "/review/leap-plus",
    compareLinks: [
      { name: "vs Aeron Size C", href: "/aeron-vs-leap-plus" },
      { name: "vs Steelcase Gesture", href: "/gesture-vs-leap-plus" },
    ],
  },
  {
    name: "Steelcase Gesture",
    suitability: 'Users 6\'0" to 6\'4" who use multiple devices',
    strengths: ["360° armrest movement", "Flexible seat edge", "Multiple sitting postures"],
    considerations: ["Smaller than Leap Plus", "Higher price point"],
    reviewHref: "/review/gesture",
    compareLinks: [
      { name: "vs Leap Plus", href: "/gesture-vs-leap-plus" },
      { name: "vs Aeron Size C", href: "/aeron-vs-gesture" },
    ],
  },
];
---

<Layout
  title="Best Office Chairs for Tall People 2026 | Tall Chair Advisor"
  description="The three ergonomic office chairs that reliably work for users 6'0&quot; and taller — with dimensional specs, fit guidance, and who each chair suits best."
  ogType="article"
  schema={schema}
>
  <header class="py-12 md:py-16 lg:py-20 bg-secondary/30">
    <div class="container-article text-center">
      <h1 class="text-balance">Best Office Chairs for Tall People</h1>
      <p class="mt-4 text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto animate-slide-up">
        A curated shortlist of chairs that meet dimensional requirements for users 6 feet and taller
      </p>
    </div>
  </header>

  <div class="container-wide py-12 md:py-16">
    <!-- Inclusion Criteria -->
    <section class="max-w-3xl mx-auto mb-16">
      <h2 class="font-serif text-2xl text-heading mb-6 text-center">Selection Criteria</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="p-4 rounded-lg bg-secondary/30 border border-border">
          <h4 class="font-medium text-heading mb-2">Included If</h4>
          <ul class="space-y-2 text-sm text-muted-foreground">
            <li class="flex items-start gap-2">
              <svg class="h-4 w-4 text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Seat height adjusts to 19"+ at maximum
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-4 w-4 text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Seat depth of 19"+ or adjustable depth
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-4 w-4 text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Back height accommodates taller torsos
            </li>
            <li class="flex items-start gap-2">
              <svg class="h-4 w-4 text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Proven track record with tall users
            </li>
          </ul>
        </div>
        <div class="p-4 rounded-lg bg-muted/30 border border-border">
          <h4 class="font-medium text-heading mb-2">Excluded If</h4>
          <ul class="space-y-2 text-sm text-muted-foreground">
            <li>• Maximum seat height under 18"</li>
            <li>• Fixed, non-adjustable seat depth under 18"</li>
            <li>• Back height designed for average users</li>
            <li>• Insufficient long-term durability data</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Chair Cards -->
    <h2 class="sr-only">Our Recommended Chairs</h2>
    <section class="space-y-8">
      {chairs.map((chair) => (
        <div class="bg-card border border-border rounded-lg p-6 md:p-8">
          <div class="flex flex-col lg:flex-row lg:items-start gap-6">
            <div class="flex-1">
              <h3 class="font-serif text-2xl text-heading mb-2">{chair.name}</h3>
              <p class="text-primary text-sm font-medium mb-4">{chair.suitability}</p>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                <div>
                  <h4 class="text-sm font-semibold text-heading mb-3">Strengths</h4>
                  <ul class="space-y-2">
                    {chair.strengths.map((strength) => (
                      <li class="flex items-start gap-2 text-sm text-muted-foreground">
                        <svg class="h-4 w-4 text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        {strength}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h4 class="text-sm font-semibold text-heading mb-3">Considerations</h4>
                  <ul class="space-y-2">
                    {chair.considerations.map((consideration) => (
                      <li class="text-sm text-muted-foreground">• {consideration}</li>
                    ))}
                  </ul>
                </div>
              </div>

              <div class="mt-6">
                <a href={chair.reviewHref} class="link-internal text-sm font-medium">
                  Read full review →
                </a>
              </div>
            </div>

            <div class="lg:w-64 flex-shrink-0">
              <h4 class="text-sm font-semibold text-heading mb-3">Compare This Chair</h4>
              <div class="space-y-2">
                {chair.compareLinks.map((link) => (
                  <a
                    href={link.href}
                    class="flex items-center justify-between p-3 rounded-lg bg-secondary/50 hover:bg-accent transition-colors text-sm"
                  >
                    <span class="text-muted-foreground">{link.name}</span>
                    <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </section>

    <!-- Educational Context -->
    <section class="mt-16 max-w-2xl mx-auto text-center">
      <p class="text-muted-foreground">
        Not sure which dimensions you need? Review our{" "}
        <a href="/correct-chair-dimensions" class="link-internal">chair dimension guide</a>{" "}
        or learn{" "}
        <a href="/how-to-adjust-chair" class="link-internal">how to adjust chairs</a>{" "}
        for tall users.
      </p>
    </section>
  </div>
</Layout>
