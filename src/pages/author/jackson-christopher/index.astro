    "image": "https://tallchairadvisor.com/images/jackson-christopher.png",
    "description": "Jackson Christopher is a 6'4\" mechanical engineering student at UC Berkeley and founder of Tall Chair Advisor. He has tested premium office chairs for over 6 years, writing guides specifically for tall users.",
    "jobTitle": "Founder, Tall Chair Advisor",
    "worksFor": {
      "@type": "Organization",
      "name": "Tall Chair Advisor",
      "url": "https://tallchairadvisor.com"
    },
    "sameAs": ["https://www.linkedin.com/in/jackson-christopher-"],
    "knowsAbout": [
      "Ergonomic office chairs",
      "Chair fit for tall people",
      "Office ergonomics",
      "Seat depth and height adjustment",
      "Back pain prevention"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tallchairadvisor.com/" },
      { "@type": "ListItem", "position": 2, "name": "Jackson Christopher", "item": "https://tallchairadvisor.com/author/jackson-christopher/" }
    ]
  }
