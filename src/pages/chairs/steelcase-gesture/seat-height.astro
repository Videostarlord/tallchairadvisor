            <td class="p-3 font-medium">6'1"</td>
            <td class="p-3 text-center text-muted-foreground">18"–19"</td>
            <td class="p-3 text-center text-muted-foreground">28"–30"</td>
            <td class="p-3 text-center text-primary font-semibold">Yes</td>
          </tr>
          <tr class="hover:bg-secondary/20">
            <td class="p-3 font-medium">6'2"</td>
            <td class="p-3 text-center text-muted-foreground">18.5"–19.5"</td>
            <td class="p-3 text-center text-muted-foreground">28.5"–30.5"</td>
