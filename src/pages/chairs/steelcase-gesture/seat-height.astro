    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the seat height range of the Steelcase Gesture?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Steelcase Gesture has a seat height range of 16 inches to 21 inches with the standard cylinder. This range accommodates desk heights from approximately 26 to 32 inches for tall users. A taller gas cylinder is available through Steelcase dealers that extends the range upward for users above 6'4\"."
        }
      },
      {
        "@type": "Question",
        "name": "What seat height should a 6'2\" person set on the Steelcase Gesture?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "At 6'2\", a seat height of approximately 18\"–19.5\" typically keeps thighs parallel to the floor with feet flat. The exact setting depends on your inseam length and desk height. Start at 18.5\" and adjust until your thighs are parallel and your knees form roughly a 90-degree angle."
        }
      },
      {
        "@type": "Question",
        "name": "What seat height should a 6'4\" person set on the Steelcase Gesture?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "At 6'4\", a seat height of approximately 19.5\"–21\" is typical. The Gesture's standard cylinder reaches 21\" at maximum, which should accommodate most users at 6'4\". Users at the taller end of 6'4\" who need more height may benefit from the optional taller cylinder available through Steelcase dealers."
        }
      },
      {
        "@type": "Question",
        "name": "How does Gesture seat height compare to the Herman Miller Aeron Size C?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Steelcase Gesture has a seat height range of 16\"–21\". The Herman Miller Aeron Size C has a range of 16\"–20.5\". The Gesture sits 0.5\" higher at maximum, which is a minor but meaningful advantage for users at the tall end of the 6'4\" range."
        }
      },
      {
        "@type": "Question",
        "name": "Is 21\" seat height enough for a tall person?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For most users up to 6'4\", a 21\" maximum seat height is sufficient when paired with an appropriately adjusted desk. At 6'5\" and above, 21\" starts to become limiting — the Steelcase Leap Plus (22.5\" maximum) or a Gesture with the optional taller gas cylinder are better options."
        }
      }
