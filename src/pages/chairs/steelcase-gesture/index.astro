          <p class="font-semibold text-heading text-base">15.75" – 18.75"</p>
        </div>
        <div class="p-4 rounded-lg bg-secondary/30 border border-border">
          <p class="text-xs text-muted-foreground mb-1">Back Height</p>
          <p class="font-semibold text-heading text-base">24"</p>
        </div>
        <div class="p-4 rounded-lg bg-secondary/30 border border-border">
          <p class="text-xs text-muted-foreground mb-1">Seat Width</p>
          <p class="font-semibold text-heading text-base">19.25"</p>
        </div>
        <div class="p-4 rounded-lg bg-secondary/30 border border-border">
          <p class="text-xs text-muted-foreground mb-1">Weight Capacity</p>
