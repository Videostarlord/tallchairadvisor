        <a href="https://www.amazon.com/s?k=steelcase+gesture+chair&tag=tallchairadvi-20" target="_blank" rel="noopener noreferrer sponsored" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-5 py-3 rounded-md font-medium hover:bg-primary/90 transition-colors text-sm">
          View Steelcase Gesture on Amazon →
        </a>
        <a href="https://www.amazon.com/s?k=Steelcase+Leap+Plus&tag=tallchairadvi-20" target="_blank" rel="noopener noreferrer sponsored" class="inline-flex items-center gap-2 border border-border text-heading px-5 py-3 rounded-md font-medium hover:bg-accent transition-colors text-sm">
          View Steelcase Leap Plus on Amazon →
        </a>
      </div>

    </div>
  </article>
</Layout>
