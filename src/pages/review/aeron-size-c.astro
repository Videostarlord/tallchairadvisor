const aeronInsightsPath = path.join(process.cwd(), 'data/reddit/published/herman-miller-aeron.json');
const aeronInsights = existsSync(aeronInsightsPath)
  ? JSON.parse(readFileSync(aeronInsightsPath, 'utf8'))
  : null;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Herman Miller Aeron Size C",
    "url": "https://tallchairadvisor.com/review/aeron-size-c/",
    "image": "https://tallchairadvisor.com/images/aeron-size-c-hero.webp",
    "description": "The Herman Miller Aeron Size C is a large-format ergonomic office chair with Pellicle mesh, PostureFit SL lumbar support, and a 350 lb weight capacity, designed for users 6'0\"–6'6\".",
    "brand": { "@type": "Brand", "name": "Herman Miller" },
    "review": {
      "@type": "Review",
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": "4.7",
        "bestRating": "5",
        "worstRating": "1"
      },
      "author": { "@type": "Person", "@id": "https://tallchairadvisor.com/about/#author", "name": "Jackson Christopher", "url": "https://tallchairadvisor.com/author/jackson-christopher/" },
      "reviewBody": "The Aeron Size C delivers exceptional breathability and proven lumbar support for tall users 6'0\"–6'4\" with lean builds. The fixed 18.5\" seat depth is the primary limitation for taller users with longer femurs.",
      "datePublished": "2025-11-12",
      "dateModified": "2026-03-07"
    },
    "offers": {
      "@type": "Offer",
      "price": "1795.00",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
            "priceValidUntil": "2027-03-01",
