const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Correct Office Chair Dimensions for Tall People",
    "url": "https://tallchairadvisor.com/correct-chair-dimensions/",
    "description": "Correct office chair dimensions for tall users: seat depth, height, back height, and armrest ranges by body height, plus how to measure your own requirements.",
    "image": "https://tallchairadvisor.com/images/og-default.webp",
    "datePublished": "2024-12-09",
    "dateModified": "2026-03-08",
    "author": { "@type": "Person", "@id": "https://tallchairadvisor.com/about/#author", "name": "Jackson Christopher", "url": "https://tallchairadvisor.com/author/jackson-christopher/" },
    "publisher": {
      "@type": "Organization",
      "name": "Tall Chair Advisor",
      "logo": { "@type": "ImageObject", "url": "https://tallchairadvisor.com/images/og-default.webp" }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tallchairadvisor.com/" },
      { "@type": "ListItem", "position": 2, "name": "Fit Guides", "item": "https://tallchairadvisor.com/fit-guides/" },
      { "@type": "ListItem", "position": 3, "name": "Correct Chair Dimensions", "item": "https://tallchairadvisor.com/correct-chair-dimensions/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the minimum chair dimensions for a tall person?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For users 6'0\"–6'2\": minimum seat depth 18–19 inches, maximum seat height 19 inches, back height 23–25 inches. For users 6'2\"–6'4\": minimum seat depth 19–20 inches, maximum seat height 20 inches, back height 25–27 inches. For users 6'4\"–6'6\": minimum seat depth 20–21 inches, maximum seat height 21 inches, back height 26–28 inches. For users 6'6\" and above: minimum seat depth 21+ inches, maximum seat height 22+ inches, back height 27+ inches. These are minimum thresholds — chairs that exceed these dimensions are preferable."
        }
      },
      {
        "@type": "Question",
        "name": "How do I measure my own body to determine what chair dimensions I need?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Three measurements determine your chair requirements: (1) Popliteal height — sit on a firm, flat surface with feet flat and measure from the floor to the crease behind your knee. This is your target seat height. (2) Thigh length — sit against a flat wall and measure from the wall to 2–3 inches before your knee crease. This is your minimum seat depth. (3) Torso length — sit upright and measure from the seat surface to your shoulder blades. The backrest must cover at least this distance."
        }
      },
      {
        "@type": "Question",
        "name": "What armrest height do tall people need?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Armrest height should match your elbow height when seated at the correct seat position, with shoulders relaxed. For users 6'0\"–6'2\", this typically means armrests that can reach 10–12 inches above the seat pan. For users 6'2\"–6'4\", 11–13 inches. For users 6'4\" and above, 12–14 inches or higher. Many standard chairs have armrests that max out at 10–11 inches above the seat, which is insufficient for tall users seated at the correct height."
        }
      },
      {
        "@type": "Question",
        "name": "What can I do if a chair's seat height doesn't go high enough?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If a chair's maximum seat height is within 1–2 inches of your popliteal height, an aftermarket extended gas cylinder is often a viable solution. Extended cylinders are available in stroke lengths that add 2–4 inches to a chair's height range. They are chair-model-specific — you need a cylinder with the correct diameter and attachment type for your chair. If the gap is larger than 2 inches, the cylinder upgrade may not be sufficient and a different chair model is likely the better path."
        }
      },
      {
        "@type": "Question",
        "name": "Why do standard chair specifications fail tall users?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Standard office chairs are designed for the 5th–95th percentile of average adult populations. The 95th percentile US male is approximately 6'2\", meaning chairs designed to cover nearly all users treat 6'2\" as an upper boundary. Users taller than 6'2\" exceed the design envelope of most chairs in at least two dimensions simultaneously — typically seat height and seat depth. This multi-dimensional shortfall is why tall users find that adjusting a standard chair improves but doesn't fully resolve their discomfort."
        }
      }
    ]
  },
