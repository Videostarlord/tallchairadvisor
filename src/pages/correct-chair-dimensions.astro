                <td class="px-4 py-3 text-muted-foreground font-medium">6'2"–6'4"</td>
                <td class="px-4 py-3 text-muted-foreground"><strong class="text-yellow-700 dark:text-yellow-400">Borderline</strong> — seat depth max 18.75" falls short of 19–20" need</td>
                <td class="px-4 py-3 text-muted-foreground"><strong class="text-green-700 dark:text-green-400">Fit</strong> — depth to 19.75", height to 22.5", back 25.5"</td>
