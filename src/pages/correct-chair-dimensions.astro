    "description": "Four measurements that determine your exact seat height, seat depth, back height, and armrest requirements for an ergonomic office chair.",
    "totalTime": "PT15M",
    "tool": [
      { "@type": "HowToTool", "name": "Measuring tape" },
      { "@type": "HowToTool", "name": "Firm, flat chair or surface" }
