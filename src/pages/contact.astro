---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://tallchairadvisor.com/contact/#webpage",
  "name": "Contact",
  "url": "https://tallchairadvisor.com/contact/",
  "isPartOf": {
    "@type": "WebSite",
    "@id": "https://tallchairadvisor.com/#website"
  }
};
---

<Layout
  title="Contact | Tall Chair Advisor"
  description="Get in touch with Tall Chair Advisor. We read every message and typically respond within 48 hours."
  noindex={true}
  schema={schema}
>
  <main class="container-wide py-16">
    <article class="prose prose-lg max-w-3xl mx-auto">
      <h1 class="font-serif text-4xl font-bold text-heading mb-8">Contact Us</h1>

      <p class="text-body mb-8">
        We welcome your feedback, questions, and suggestions. Tall Chair Advisor is committed
        to providing helpful, accurate information for tall and large individuals seeking
        ergonomic seating solutions.
      </p>

      <section class="mb-8">
        <h2 class="font-serif text-2xl font-semibold text-heading mb-4">General Inquiries</h2>
        <p class="text-body mb-4">
          For general questions about our content, methodology, or recommendations, please
          reach out via email. We aim to respond to all inquiries within 2-3 business days.
        </p>
        <p class="text-body">
          <strong>Email:</strong>
          <span
            id="contact-email"
            data-user="Jacksonchristopher"
            data-domain="berkeley"
            data-tld="edu"
          >
            Jacksonchristopher [at] berkeley [dot] edu
          </span>
        </p>
      </section>

      <section class="mb-8">
        <h2 class="font-serif text-2xl font-semibold text-heading mb-4">Content Corrections</h2>
        <p class="text-body">
          If you notice any errors in our content or have updated information about products
          we review, please let us know. We strive to maintain accurate, up-to-date information
          and appreciate reader contributions.
        </p>
      </section>

      <section class="mb-8">
        <h2 class="font-serif text-2xl font-semibold text-heading mb-4">Business Inquiries</h2>
        <p class="text-body">
          For business-related matters, partnership opportunities, or press inquiries,
          please contact us at the email address above with "Business Inquiry" in the
          subject line.
        </p>
      </section>

      <section class="mb-8">
        <h2 class="font-serif text-2xl font-semibold text-heading mb-4">Response Times</h2>
        <p class="text-body">
          We are a small team dedicated to creating quality content. While we read every
          message, we may not be able to respond to all inquiries individually. Thank you
          for your understanding.
        </p>
      </section>
    </article>
  </main>
</Layout>

<script is:inline>
  // Build the email link client-side so Cloudflare doesn't replace it with a dead crawlable URL.
  const emailTarget = document.getElementById('contact-email');

  if (emailTarget instanceof HTMLElement) {
    const user = emailTarget.dataset.user;
    const domain = emailTarget.dataset.domain;
    const tld = emailTarget.dataset.tld;

    if (user && domain && tld) {
      const email = `${user}@${domain}.${tld}`;
      const link = document.createElement('a');
      link.href = `mailto:${email}`;
      link.textContent = email;
      link.className = 'underline text-primary hover:text-primary/80';
      emailTarget.replaceWith(link);
    }
  }
</script>
