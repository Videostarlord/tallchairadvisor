---
const currentYear = new Date().getFullYear();

const footerLinks = {
  resources: [
    { name: "Pain & Ergonomics", href: "/pain-ergonomics" },
    { name: "Fit Guides", href: "/fit-guides" },
    { name: "Best Office Chairs", href: "/best-office-chairs" },
  ],
  comparisons: [
    { name: "Aeron vs Leap Plus", href: "/aeron-vs-leap-plus" },
    { name: "Gesture vs Leap Plus", href: "/gesture-vs-leap-plus" },
    { name: "Aeron vs Gesture", href: "/aeron-vs-gesture" },
  ],
  reviews: [
    { name: "Herman Miller Aeron Size C", href: "/review/aeron-size-c" },
    { name: "Steelcase Leap Plus", href: "/review/leap-plus" },
    { name: "Steelcase Gesture", href: "/review/gesture" },
  ],
};
---

<footer class="bg-card border-t border-border mt-20">
  <div class="container-wide py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="font-serif text-xl font-semibold text-heading">
          Tall Chair Advisor
        </a>
        <p class="mt-4 text-sm text-muted-foreground leading-relaxed">
          Expert guidance on ergonomic office chairs for tall and large individuals.
          Independent reviews and comparisons.
        </p>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="font-sans text-sm font-semibold text-heading mb-4">Resources</h4>
        <ul class="space-y-3">
          {footerLinks.resources.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted-foreground hover:text-primary transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Comparisons -->
      <div>
        <h4 class="font-sans text-sm font-semibold text-heading mb-4">Comparisons</h4>
        <ul class="space-y-3">
          {footerLinks.comparisons.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted-foreground hover:text-primary transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Reviews -->
      <div>
        <h4 class="font-sans text-sm font-semibold text-heading mb-4">Reviews</h4>
        <ul class="space-y-3">
          {footerLinks.reviews.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted-foreground hover:text-primary transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-sm text-muted-foreground">
          &copy; {currentYear} Tall Chair Advisor. All rights reserved.
        </p>
        <div class="flex flex-wrap justify-center gap-4 md:gap-6">
          <a href="/about/" class="text-sm text-muted-foreground hover:text-primary transition-colors">About Us</a>
          <a href="/privacy-policy" class="text-sm text-muted-foreground hover:text-primary transition-colors">Privacy Policy</a>
          <a href="/contact" class="text-sm text-muted-foreground hover:text-primary transition-colors">Contact</a>
          <a href="/affiliate-disclosure" class="text-sm text-muted-foreground hover:text-primary transition-colors">Affiliate Disclosure</a>
        </div>
      </div>
    </div>
  </div>
</footer>
