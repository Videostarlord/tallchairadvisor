---
const navigation = [
  {
    name: "Pain & Ergonomics",
    href: "/pain-ergonomics",
    children: [
      { name: "Why Standard Chairs Don't Fit", href: "/why-standard-chairs-dont-fit" },
      { name: "Knee Pain & Seat Depth", href: "/knee-pain-seat-depth" },
      { name: "Back Pain & Spine Height", href: "/back-pain-spine-height" },
      { name: "Leg Pain & Circulation", href: "/leg-pain-circulation" },
    ],
  },
  {
    name: "Fit Guides",
    href: "/fit-guides",
    children: [
      { name: "Correct Chair Dimensions", href: "/correct-chair-dimensions" },
      { name: "How to Adjust Your Chair", href: "/how-to-adjust-chair" },
    ],
  },
  {
    name: "Best Chairs",
    href: "/best-office-chairs",
  },
  {
    name: "Reviews",
    href: "#",
    children: [
      { name: "Steelcase Gesture", href: "/review/gesture" },
      { name: "Herman Miller Aeron Size C", href: "/review/aeron-size-c" },
      { name: "Steelcase Leap Plus", href: "/review/leap-plus" },
    ],
  },
  {
    name: "Comparisons",
    href: "#",
    children: [
      { name: "Aeron vs Leap Plus", href: "/aeron-vs-leap-plus" },
      { name: "Gesture vs Leap Plus", href: "/gesture-vs-leap-plus" },
      { name: "Aeron vs Gesture", href: "/aeron-vs-gesture" },
    ],
  },
  {
    name: "About",
    href: "/about",
  },
];
---

<header class="sticky top-0 z-50 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80 border-b border-border">
  <nav class="container-wide">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2">
        <span class="font-serif text-xl font-semibold text-heading">
          Tall Chair Advisor
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex lg:items-center lg:space-x-1">
        {navigation.map((item) => (
          <div class="relative group" data-dropdown>
            {item.children ? (
              <>
                <button
                  class="flex items-center px-3 py-2 text-sm font-medium transition-colors rounded-md text-muted-foreground hover:text-foreground hover:bg-muted"
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  {item.name}
                  <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="absolute left-0 top-full pt-1 w-56 hidden group-hover:block">
                  <div class="bg-card rounded-lg shadow-lg border border-border py-2">
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class="block px-4 py-2 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors"
                      >
                        {child.name}
                      </a>
                    ))}
                  </div>
                </div>
              </>
            ) : (
              <a
                href={item.href}
                class="px-3 py-2 text-sm font-medium transition-colors rounded-md block text-muted-foreground hover:text-foreground hover:bg-muted"
              >
                {item.name}
              </a>
            )}
          </div>
        ))}
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-muted-foreground hover:text-foreground"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="icon-menu" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="lg:hidden hidden border-t border-border py-4">
      {navigation.map((item) => (
        <div class="mobile-nav-item">
          {item.children ? (
            <>
              <button
                class="mobile-dropdown-btn flex items-center justify-between w-full px-4 py-3 text-sm font-medium text-muted-foreground"
                aria-expanded="false"
              >
                {item.name}
                <svg class="chevron h-4 w-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="mobile-dropdown hidden bg-muted/50 py-2">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-8 py-2 text-sm text-muted-foreground hover:text-foreground"
                  >
                    {child.name}
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a
              href={item.href}
              class="block px-4 py-3 text-sm font-medium text-muted-foreground hover:text-foreground"
            >
              {item.name}
            </a>
          )}
        </div>
      ))}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  document.querySelectorAll('.mobile-dropdown-btn').forEach((dropBtn) => {
    dropBtn.addEventListener('click', () => {
      const parent = dropBtn.closest('.mobile-nav-item');
      const dropdown = parent?.querySelector('.mobile-dropdown');
      const chevron = dropBtn.querySelector('.chevron');
      const isOpen = !dropdown?.classList.contains('hidden');
      dropdown?.classList.toggle('hidden', isOpen);
      chevron?.classList.toggle('rotate-180', !isOpen);
      dropBtn.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
